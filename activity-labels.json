    "pstl_380":     { "name": "Pistols Manufactured – .380 cal", "group": "Pistols",   "activity": "Manufactured", "caliber": ".380" },
    "pstl_9mm":     { "name": "Pistols Manufactured – 9mm",      "group": "Pistols",   "activity": "Manufactured", "caliber": "9mm" },
